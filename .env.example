# =====================================================================
# Copy this file to `.env` (gitignored) and fill in the real values.
# Never commit `.env`. See README.md "Security" for token rotation.
# =====================================================================

# ---- Postgres (used by docker-compose + Prisma) ----
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=realestate
# Host port mapping — change if 5432 is taken locally.
POSTGRES_PORT=5432
# Connection string used by Prisma (web + worker).
# When running OUTSIDE docker (host machine), use localhost.
# When running INSIDE docker, the container hostname is `db`.
DATABASE_URL=postgresql://app:app@localhost:5432/realestate?schema=public

# ---- Redis (BullMQ) ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- Web app ----
WEB_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Auth (single-user v1) ----
# Long random string. Used to sign session cookies and guest-form magic links.
AUTH_SECRET=replace-me-with-a-32-byte-random-string
ADMIN_EMAIL=you@example.com
# Used as a simple shared-secret login for v1. Change before any deploy.
ADMIN_PASSWORD=changeme

# ---- Telegram bot ----
# Get from @BotFather → /newbot. Long-polling, no webhook needed for local dev.
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram user ID (the only user the bot will respond to in v1).
# Find it by messaging @userinfobot.
TELEGRAM_ADMIN_USER_ID=

# ---- AI runtime (OpenAI-compatible) ----
# Default: OpenCode Zen "big-pickle" free tier.
# Swap to Ollama / Gemini Flash / OpenAI by changing these three lines.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://opencode.ai/zen/v1
AI_MODEL=big-pickle

# ---- iCal polling ----
ICAL_POLL_INTERVAL_MINUTES=15
ICAL_FETCH_TIMEOUT_MS=10000

# ---- Logging ----
LOG_LEVEL=info
NODE_ENV=development
